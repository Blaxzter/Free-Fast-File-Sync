{
  "name": "fast-file-sync",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Reliable fast two-way file sync that respects .gitignore — Rust core + Tauri UI",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:e2e": "cross-env VITE_E2E=1 vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "app": "tauri dev",
    "app:build": "tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:mocked": "playwright test",
    "e2e:native": "wdio run wdio.conf.ts",
    "gen:testdata": "node scripts/gen-testdata.mjs",
    "format": "biome check --write .",
    "format:check": "biome check ."
  },
  "dependencies": {
    "@radix-ui/react-switch": "^1.3.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "lucide-react": "^1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@playwright/test": "^1.50.1",
    "@tauri-apps/cli": "2.11.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.13.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "^3.0.5",
    "@wdio/cli": "^9.7.2",
    "@wdio/globals": "^9.7.2",
    "@wdio/local-runner": "^9.7.2",
    "@wdio/mocha-framework": "^9.7.2",
    "@wdio/spec-reporter": "^9.7.2",
    "cross-env": "^7.0.3",
    "jsdom": "^25.0.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "^3.0.5",
    "webdriverio": "^9.7.2"
  }
}
