# Normalize line endings to LF in the repo (multi-OS project).
* text=auto eol=lf

# Binary assets — never touch.
*.png binary
*.ico binary
*.icns binary
*.cr2 binary
*.psd binary

# Lockfiles: keep diffs but mark as generated for review tooling.
pnpm-lock.yaml linguist-generated=true
Cargo.lock linguist-generated=true
